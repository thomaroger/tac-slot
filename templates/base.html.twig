<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>Les Archers du Faucigny - Système de réservation tir libre</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">

        <!-- CSS Bootstrap mobile-first -->
        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
            crossorigin="anonymous"
        >
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
        <link rel="stylesheet" href="{{ asset('css/app.css') }}">
        {% block stylesheets %}{% endblock %}
    </head>
    <body class="bg-light">
        <header class="navbar navbar-expand-lg navbar-dark bg-arc mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-semibold" href="{{ path('app_home') }}">Les Archers du Faucigny - Système de réservation tir libre</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Afficher le menu">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <nav id="mainNavbar" class="collapse navbar-collapse">
                    <ul class="navbar-nav ms-auto">
                        {% if is_granted('ROLE_USER') %}
                        <li class="nav-item">
                            <span class="nav-link">{{user.firstName}} {{user.lastName}} {% if user.hasAirKey %} <i class="fa-solid fa-key">&nbsp;</i>{% endif %}  - {{user.level}}</span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link selected" href="{{ path('app_home') }}">Accueil</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('reservations_my') }}">Mes réservations</a>
                        </li>
                        {% endif %}
                        {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item">
                            <a class="nav-link" target="_blank" href="{{ path('admin') }}">Admin</a>
                        </li>
                        {% endif %}
                        {% if is_granted('ROLE_USER') %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_logout') }}">Se déconnecter</a>
                        </li>
                        {% endif %}
                    </ul>
                </nav>
            </div>
        </header>

        <main class="container mb-5">
            {% block body %}{% endblock %}
            <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1080;">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="toast align-items-center text-bg-{{ label }} border-0" role="status" aria-live="polite" aria-atomic="true" data-bs-delay="4000">
                            <div class="d-flex">
                                <div class="toast-body">{{ message }}</div>
                                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                            </div>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>
        </main>

        <footer class="text-center text-muted small py-3">
            &copy; {{ "now"|date("Y") }} - Les Archers du Faucigny - Système de réservation tir libre
        </footer>

        <!-- JS Bootstrap (pour le menu mobile) -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
                integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
                crossorigin="anonymous"></script>
        <script src="https://kit.fontawesome.com/de5a114b19.js" crossorigin="anonymous"></script>
        <script defer src="{{ asset('js/app.js') }}"></script>

        {% block javascripts %}{% endblock %}
</body>
</html>
