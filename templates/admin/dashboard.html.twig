                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h2 class="h5 mb-2">Nombre d'adhérent ayant réservé un créneau</h2>
                        <p class="display-6 mb-1">
                            {{ reservation_count_adherent_7 ?? 0 }}
                        </p>
