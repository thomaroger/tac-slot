                    <div class="card-body">
                        <h2 class="h5 mb-2">TOP 5 des créneaux</h2>
                        <p class="mb-1 text-muted text-center">
                            {% for date, value in slot_with_number_of_reservation_top5 %}
                                {{date}} : <strong>{{value}} réservations</strong> <br />
                            {% endfor %}
                        </p>
