                        </p>
                        <p class="text-muted mb-0">
                            Nombre de réservation en cours aujourd'hui
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h2 class="h5 mb-2">Nombre de réservations non honorées (No-Show)</h2>
                        <p class="display-6 mb-1">
                            {{ reservation_noshow_count_today ?? 0 }}
                        </p>
                        <p class="text-muted mb-0">
                            Nombre de réservation non honorée aujourd'hui
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h2 class="h5 mb-2">Nombre d'adhérent ayant réservé un créneau</h2>
                        <p class="display-6 mb-1">
                            {{ reservation_count_adherent_today ?? 0 }}
                        </p>
                        <p class="text-muted mb-0">
                            NNombre d'adhérent ayant réservé un creneau aujourd'hui
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h2 class="h5 mb-2">Taux de remplissage</h2>
                        <p class="display-6 mb-1">
                            {{tx_resa_today|round(2, 'floor') }} %
                        </p>
                        <p class="text-muted mb-0">
                            Nombre de personnes présentes par rapport au nombre de places disponible
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

