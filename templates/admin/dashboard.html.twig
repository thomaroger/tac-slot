{% extends '@EasyAdmin/page/content.html.twig' %}
{% block content_title %}{{ page_title }}{% endblock %}
{% block main %}
    <section class="py-4">
        <h1 class="h3 mb-3">Tableau de bord global</h1>
        <div class="row g-3">
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h2 class="h5 mb-2">Adhérents</h2>
                        <p class="display-6 mb-1">
                            {{ adherents_count ?? 0 }}
                        </p>
                        <p class="text-muted mb-0">
                            Nombre de licenciés total.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h2 class="h5 mb-2">Créneaux</h2>
                        <p class="display-6 mb-1">
                            {{ slot_count ?? 0 }}
                        </p>
                        <p class="text-muted mb-0">
                            Nombre de créneaux total.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h2 class="h5 mb-2">Réservations</h2>
                        <p class="display-6 mb-1">
                            {{ reservation_count ?? 0 }}
                        </p>
                        <p class="text-muted mb-0">
                            Nombre de réservations total.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100 bg-success text-white">
                    <div class="card-body">
                        <h2 class="h5 mb-2 text-white">Nombre de réservations avec checkin</h2>
                        <p class="display-6 mb-1">
                            {{ reservation_count_with_checkin ?? 0 }}
                        </p>
                        <p class="text-white mb-0">
                            Nombre total de réservation avec checkin à la salle.
                        </p>
                    </div>
                </div>
            </div>
             <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100 bg-success">
                    <div class="card-body">
                        <h2 class="h5 mb-2 text-white">Nombre de réservations confirmées</h2>
                        <p class="display-6 mb-1 text-white">
                            {{ reservation_count_confirmed ?? 0 }}
                        </p>
                    </div>
                </div>
            </div>
             <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100 bg-warning">
                    <div class="card-body">
                        <h2 class="h5 mb-2">Nombre de réservations annulées</h2>
                        <p class="display-6 mb-1">
                            {{ reservation_count_cancelled ?? 0 }}
                        </p>
                        <p class="text-muted mb-0">
                            Nombre de réservations annulées par l'adhérent.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100 bg-danger">
                    <div class="card-body">
                        <h2 class="h5 mb-2 text-white">Nombre de réservations non honorées</h2>
                        <p class="display-6 mb-1 text-white">
                            {{ reservation_count_noshow ?? 0 }}
                        </p>
                        <p class="text-white mb-0">
                            Nombre de réservations confirmées sans checkin à la salle.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h2 class="h5 mb-2">Nombre moyen de réservations confirmées par adhérent</h2>
                        <p class="display-6 mb-1">
                            {{ (reservation_count_confirmed/adherents_active_count)|round(2, 'floor')  }}
                        </p>
                        <p class="text-muted mb-0">
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h2 class="h5 mb-2">Taux de fiabilité global</h2>
                        <p class="display-6 mb-1">
                            {{ ((reservation_count_with_checkin/(reservation_count_noshow+reservation_count_with_checkin))*100)|round(2, 'floor')  }}%
                        </p>
                        <p class="text-muted mb-0">
                            Pourcentage du nombre de reservation checkin par rapport au nombre de réservations confirmées
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h2 class="h5 mb-2">Taux de No Show</h2>
                        <p class="display-6 mb-1">
                            {{ ((reservation_count_noshow/(reservation_count_noshow+reservation_count_with_checkin))*100)|round(2, 'floor')  }}%
                        </p>
                        <p class="text-muted mb-0">
                            Pourcentage du nombre de reservation avec un no-show par rapport au nombre de réservations confirmées
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-4">
