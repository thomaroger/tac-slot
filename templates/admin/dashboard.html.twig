{% block body_javascript %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            const canvas = document.getElementById('reservationStatusTrend15dChart');
            if (!canvas || typeof Chart === 'undefined') {
                return;
            }

            const trend = {{ reservation_status_trend_mixed|json_encode|raw }};

            const datasetConfig = [
                {
                    key: 'confirmed',
                    label: 'Confirmées / Check-in',
                    borderColor: '#155724',
                    backgroundColor: 'rgba(21, 87, 36, 0.14)'
                },
                {
                    key: 'pending',
                    label: 'En attente',
                    borderColor: '#7a4f01',
                    backgroundColor: 'rgba(122, 79, 1, 0.14)'
                },
                {
                    key: 'cancelled',
                    label: 'Annulées',
                    borderColor: '#5f6770',
                    backgroundColor: 'rgba(95, 103, 112, 0.14)'
                },
                {
                    key: 'no_show',
                    label: 'No-show',
                    borderColor: '#842029',
                    backgroundColor: 'rgba(132, 32, 41, 0.14)'
                }
            ];

            const buildDatasets = (chartTrend) => datasetConfig.map((cfg) => ({
                label: cfg.label,
                metricKey: cfg.key,
                data: (chartTrend.datasets && chartTrend.datasets[cfg.key]) ? chartTrend.datasets[cfg.key] : [],
                borderColor: cfg.borderColor,
                backgroundColor: cfg.backgroundColor,
                tension: 0.25,
                fill: false,
                borderWidth: 2,
                pointRadius: 3
            }));

            const chart = new Chart(canvas, {
                type: 'line',
                data: {
                    labels: trend.labels || [],
                    datasets: buildDatasets(trend)
                },
                plugins: [{
                    id: 'todayMarker',
                    beforeDraw(chartInstance) {
                        const todayIndex = Number.isInteger(trend.today_index) ? trend.today_index : 14;
                        const xScale = chartInstance.scales.x;
                        const chartArea = chartInstance.chartArea;

                        if (!xScale || !chartArea || todayIndex < 0 || todayIndex >= chartInstance.data.labels.length) {
                            return;
                        }

                        const x = xScale.getPixelForValue(todayIndex);
                        const ctx = chartInstance.ctx;

                        ctx.save();
                        ctx.fillStyle = 'rgba(12, 99, 228, 0.06)';
                        ctx.fillRect(x, chartArea.top, chartArea.right - x, chartArea.bottom - chartArea.top);
                        ctx.restore();
                    },
                    afterDraw(chartInstance) {
                        const todayIndex = Number.isInteger(trend.today_index) ? trend.today_index : 14;
                        const xScale = chartInstance.scales.x;
                        const yScale = chartInstance.scales.y;
                        const chartArea = chartInstance.chartArea;

                        if (!xScale || !yScale || todayIndex < 0 || todayIndex >= chartInstance.data.labels.length) {
                            return;
                        }

                        const x = xScale.getPixelForValue(todayIndex);
                        const top = yScale.top;
                        const bottom = yScale.bottom;
                        const ctx = chartInstance.ctx;

                        ctx.save();
                        ctx.beginPath();
                        ctx.moveTo(x, top);
                        ctx.lineTo(x, bottom);
                        ctx.lineWidth = 2;
                        ctx.strokeStyle = '#0c63e4';
                        ctx.setLineDash([6, 4]);
                        ctx.stroke();
                        ctx.setLineDash([]);

                        ctx.fillStyle = '#0c63e4';
                        ctx.font = '600 12px sans-serif';
                        ctx.textAlign = 'center';
                        ctx.fillText('Aujourd\'hui', x, top - 8);
                        ctx.textAlign = 'right';
                        ctx.fillStyle = 'rgba(12, 99, 228, 0.85)';
                        ctx.fillText('Futur', chartArea.right - 6, top + 14);
                        ctx.restore();
                    }
                }],
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: 'index',
                        intersect: false
                    },
                    plugins: {
                        legend: {
                            position: 'top'
                        },
                        tooltip: {
                            callbacks: {
                                title(context) {
                                    const index = context && context[0] ? context[0].dataIndex : -1;
                                    if (index < 0 || !trend.full_labels || !trend.full_labels[index]) {
                                        return '';
                                    }

                                    return trend.full_labels[index];
                                },
                                label(context) {
                                    const index = context.dataIndex;
                                    const value = context.parsed && Number.isFinite(context.parsed.y) ? context.parsed.y : 0;
                                    const metricKey = context.dataset ? context.dataset.metricKey : '';
                                    const todayIndex = Number.isInteger(trend.today_index) ? trend.today_index : 14;

                                    if (metricKey === 'confirmed' && index < todayIndex) {
                                        return 'Check-in: ' + value;
                                    }

                                    if (metricKey === 'confirmed') {
                                        return 'Confirmées: ' + value;
                                    }

                                    return context.dataset.label + ': ' + value;
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                precision: 0
                            }
                        }
                    }
                }
            });
        })();
    </script>
{% endblock %}
