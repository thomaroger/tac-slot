            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h2 class="h5 mb-2">TOP 5 des adhérents les plus fiables</h2>
                        <p class="mb-1 text-muted text-center">
                            {% for adherent in top5_adherents %}
                                {{adherent.firstName}} {{adherent.lastName}} : <strong>{{(adherent.ratio*100)|round(2, 'floor')}} %</strong> <br />
                            {% endfor %}
                        </p>
                        <p class="text-muted mb-0">
                            Ratio entre les reservations qui ont été checkin par rapport au nombre de réservations confirmées
