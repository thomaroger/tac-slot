    <section class="py-4">
        <h1 class="h3 mb-3">KPIs Adhérents</h1>
        <div class="row g-3">
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h2 class="h5 mb-2">Nombre d'adhérents actifs</h2>
                        <p class="display-6 mb-1">
                         {{ adherents_active_count ?? 0 }} / {{ adherents_count ?? 0 }}
                        </p>
                        <p class="text-muted mb-0">
                            Nombre de licenciés actifs.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
