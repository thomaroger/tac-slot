{% extends 'base.html.twig' %}

{% block body %}
<section class="py-4 kpi-section">
<div class="row g-3">
    {% set confirmed_total = reservation_count_noshow + reservation_count_with_checkin %}
	    <div class="col-12 col-md-6 col-lg-4">
	        <div class="card shadow-sm border-0 h-100 kpi-state-reserved">
	            <div class="card-body">
	                <h2 class="kpi-card-title mb-2">Nombre de réservations avec checkin</h2>
                <p class="kpi-card-value mb-1">
                    {{reservation_count_with_checkin}}
                </p>
            </div>
        </div>
    </div>
        <div class="col-12 col-md-6 col-lg-4">
        <div class="card shadow-sm border-0 h-100 kpi-state-reserved">
            <div class="card-body">
                <h2 class="kpi-card-title mb-2">Nombre de réservations confirmées</h2>
                <p class="kpi-card-value mb-1">
                    {{reservation_count_confirmed}}
                </p>
            </div>
        </div>
    </div>
        <div class="col-12 col-md-6 col-lg-4">
        <div class="card shadow-sm border-0 h-100 kpi-state-pending">
            <div class="card-body">
                <h2 class="kpi-card-title mb-2">Nombre de réservations annulées</h2>
                <p class="kpi-card-value mb-1">
                    {{reservation_count_cancelled}}
                </p>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-lg-4">
        <div class="card shadow-sm border-0 h-100 kpi-state-closed">
            <div class="card-body">
                <h2 class="kpi-card-title mb-2">Nombre de réservations non honorées</h2>
                <p class="kpi-card-value mb-1">
                    {{reservation_count_noshow}}
                </p>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-lg-4">
	                <div class="card shadow-sm border-0 h-100 kpi-state-reserved">
	                    <div class="card-body">
	                        <h2 class="kpi-card-title mb-2">Taux de fiabilité global</h2>
	                        <p class="kpi-card-value mb-1">
	                            {{ confirmed_total > 0 ? ((reservation_count_with_checkin / confirmed_total) * 100)|round(2, 'floor') : 0 }}%
	                        </p>
	                        <p class="kpi-card-caption mb-0">
	                            Pourcentage du nombre de reservation checkin par rapport au nombre de réservations confirmées
	                        </p>
	                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
	                <div class="card shadow-sm border-0 h-100 kpi-state-closed">
	                    <div class="card-body">
	                        <h2 class="kpi-card-title mb-2">Taux de No Show</h2>
	                        <p class="kpi-card-value mb-1">
	                            {{ confirmed_total > 0 ? ((reservation_count_noshow / confirmed_total) * 100)|round(2, 'floor') : 0 }}%
	                        </p>
	                        <p class="kpi-card-caption mb-0">
	                            Pourcentage du nombre de reservation avec un no-show par rapport au nombre de réservations confirmées
	                        </p>
	                    </div>
                </div>
            </div>
            </div>
    </section>



<div class="container-fluid py-4" id="my-reservations-accordion">
    <h2 class="mb-4 fw-bold">Mes réservations</h2>
    <div class="card reservation-section-card">
        <div class="card-header p-0">
            <button
                class="reservation-collapse-toggle d-flex w-100 justify-content-between align-items-center"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#current-reservations-collapse"
                aria-expanded="true"
                aria-controls="current-reservations-collapse"
            >
                <span>Réservations du {{ start_of_day|fr_date('l d F') }}</span>
                <i class="fa-solid fa-chevron-down reservation-toggle-icon" aria-hidden="true"></i>
            </button>
        </div>
        <div id="current-reservations-collapse" class="collapse show" data-bs-parent="#my-reservations-accordion">
            <div class="card-body js-reservation-period" data-filter-group="current">
                <div class="d-flex flex-wrap gap-2 mb-3 justify-content-center">
                    <button type="button" class="btn btn-sm js-reservation-filter is-active" data-filter-group="current" data-filter-status="all">Toutes</button>
                    <button type="button" class="btn btn-sm js-reservation-filter" data-filter-group="current" data-filter-status="confirmed_checkin">Check-in</button>
                    <button type="button" class="btn btn-sm js-reservation-filter" data-filter-group="current" data-filter-status="no_show">No-show</button>
                    <button type="button" class="btn btn-sm js-reservation-filter" data-filter-group="current" data-filter-status="confirmed">Confirmée</button>
                    <button type="button" class="btn btn-sm js-reservation-filter" data-filter-group="current" data-filter-status="cancelled">Annulée</button>
                </div>
             {% for reservation in current_reservations %}
                {% set reservationState = 'normal' %}
                    {% if reservation.status == 'confirmed' %}
                        {% set reservationState = 'reserved' %}
                    {% elseif reservation.status == 'cancelled' %}
                        {% set reservationState = 'pending' %}
                    {% elseif reservation.status == 'no_show' %}
                        {% set reservationState = 'closed' %}
                    {% endif %}
                    {% set quickStatus = reservation.status %}
                    {% if reservation.status == 'confirmed' and reservation.isCheckedIn == true %}
                        {% set quickStatus = 'confirmed_checkin' %}
                    {% endif %}
                    <div class="card slot-card slot-state-{{ reservationState }} mt-2 js-reservation-item" data-filter-group="current" data-reservation-status="{{ quickStatus }}" id=''>
                        <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                {{ reservation.slot.startAt|fr_date('l d F') }} : <strong>{{ reservation.slot.startAt|date('H:i') }} - {{ reservation.slot.endAt|date('H:i') }}</strong><br>
                            </div>
                            <div>
                                {% if reservation.status == 'confirmed' %}
                                    <span class="status-badge badge-reserved">Réservé</span>
                                {% elseif reservation.status == 'cancelled' %}
                                    <span class="status-badge badge-pending">Annulé</span>
                                {% elseif reservation.status == 'no_show' %}
                                    <span class="status-badge badge-noshow">No-show</span>
                                {% else %}
                                    <span class="status-badge badge-neutral">{{ reservation.status|capitalize }}</span>
                                {% endif %}
                                {% if reservation.isCheckedIn == true %}
                                    <span class="status-badge badge-checkin">Check-in</span>
                                {% endif %}
                            </div>
                        </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
    <div class="clearfix">&nbsp;</div>
    <div class="card reservation-section-card">
        <div class="card-header p-0">
            <button
                class="reservation-collapse-toggle d-flex w-100 justify-content-between align-items-center collapsed"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#future-reservations-collapse"
                aria-expanded="false"
                aria-controls="future-reservations-collapse"
            >
                <span>Réservations futures</span>
                <i class="fa-solid fa-chevron-down reservation-toggle-icon" aria-hidden="true"></i>
            </button>
        </div>
        <div id="future-reservations-collapse" class="collapse" data-bs-parent="#my-reservations-accordion">
            <div class="card-body js-reservation-period" data-filter-group="future">
                <div class="d-flex flex-wrap gap-2 mb-3 justify-content-center">
                    <button type="button" class="btn btn-sm js-reservation-filter is-active" data-filter-group="future" data-filter-status="all">Toutes</button>
                    <button type="button" class="btn btn-sm js-reservation-filter" data-filter-group="future" data-filter-status="confirmed">Confirmée</button>
                    <button type="button" class="btn btn-sm js-reservation-filter" data-filter-group="future" data-filter-status="pending">En cours</button>

                    <button type="button" class="btn btn-sm js-reservation-filter" data-filter-group="future" data-filter-status="cancelled">Annulée</button>
                </div>
         {% for reservation in futur_reservations %}
                {% set reservationState = 'normal' %}
                    {% if reservation.status == 'confirmed' %}
                        {% set reservationState = 'reserved' %}
                    {% elseif reservation.status == 'pending' %}
                        {% set reservationState = 'closed' %}
                    {% elseif reservation.status == 'cancelled' %}
                        {% set reservationState = 'pending' %}
                    {% elseif reservation.status == 'no_show' %}
                        {% set reservationState = 'closed' %}
                    {% endif %}
                    {% set quickStatus = reservation.status %}
                    {% if reservation.status == 'confirmed' and reservation.isCheckedIn == true %}
                        {% set quickStatus = 'confirmed_checkin' %}
                    {% endif %}
                    <div class="card slot-card slot-state-{{ reservationState }} mt-2 js-reservation-item" data-filter-group="future" data-reservation-status="{{ quickStatus }}" id=''>
                        <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                {{ reservation.slot.startAt|fr_date('l d F') }} : <strong>{{ reservation.slot.startAt|date('H:i') }} - {{ reservation.slot.endAt|date('H:i') }}</strong><br>
                            </div>
                            <div>
                                {% if reservation.status == 'confirmed' %}
                                    <span class="status-badge badge-reserved">Réservé</span>
                                {% elseif reservation.status == 'cancelled' %}
                                    <span class="status-badge badge-pending">Annulé</span>
                                {% elseif reservation.status == 'pending' %}
                                    <span class="status-badge badge-noshow">En cours</span>
                                {% else %}
                                    <span class="status-badge badge-neutral">{{ reservation.status|capitalize }}</span>
                                {% endif %}
                            </div>
                        </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
    <div class="clearfix">&nbsp;</div>
    <div class="card reservation-section-card">
        <div class="card-header p-0">
            <button
                class="reservation-collapse-toggle d-flex w-100 justify-content-between align-items-center collapsed"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#past-reservations-collapse"
                aria-expanded="false"
                aria-controls="past-reservations-collapse"
            >
                <span>Réservations passées</span>
                <i class="fa-solid fa-chevron-down reservation-toggle-icon" aria-hidden="true"></i>
            </button>
        </div>
        <div id="past-reservations-collapse" class="collapse" data-bs-parent="#my-reservations-accordion">
            <div class="card-body js-reservation-period" data-filter-group="past">
                <div class="d-flex flex-wrap gap-2 mb-3 justify-content-center">
                    <button type="button" class="btn btn-sm js-reservation-filter is-active" data-filter-group="past" data-filter-status="all">Toutes</button>
                    <button type="button" class="btn btn-sm js-reservation-filter" data-filter-group="past" data-filter-status="confirmed_checkin">Check-in</button>
                    <button type="button" class="btn btn-sm js-reservation-filter" data-filter-group="past" data-filter-status="no_show">No-show</button>
                    <button type="button" class="btn btn-sm js-reservation-filter" data-filter-group="past" data-filter-status="cancelled">Annulée</button>
                </div>
            {% for reservation in past_reservations %}
                {% set reservationState = 'normal' %}
                    {% if reservation.status == 'confirmed' %}
                        {% set reservationState = 'reserved' %}
                    {% elseif reservation.status == 'cancelled' %}
                        {% set reservationState = 'pending' %}
                    {% elseif reservation.status == 'no_show' %}
                        {% set reservationState = 'closed' %}
                    {% endif %}
                    {% set quickStatus = reservation.status %}
                    {% if reservation.status == 'confirmed' and reservation.isCheckedIn == true %}
                        {% set quickStatus = 'confirmed_checkin' %}
                    {% endif %}
                    <div class="card slot-card slot-state-{{ reservationState }} mt-2 js-reservation-item" data-filter-group="past" data-reservation-status="{{ quickStatus }}" id=''>
                        <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                {{ reservation.slot.startAt|fr_date('l d F') }} : <strong>{{ reservation.slot.startAt|date('H:i') }} - {{ reservation.slot.endAt|date('H:i') }}</strong><br>
                            </div>
                            <div>
                                {% if reservation.status == 'confirmed' %}
                                    <span class="status-badge badge-reserved">Réservé</span>
                                {% elseif reservation.status == 'cancelled' %}
                                    <span class="status-badge badge-pending">Annulé</span>
                                {% elseif reservation.status == 'no_show' %}
                                    <span class="status-badge badge-noshow">No-show</span>
                                {% else %}
                                    <span class="status-badge badge-neutral">{{ reservation.status|capitalize }}</span>
                                {% endif %}
                                {% if reservation.isCheckedIn == true %}
                                    <span class="status-badge badge-checkin">Check-in</span>
                                {% endif %}
                            </div>
                        </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
<div>
{% endblock %}

{% block javascripts %}
{% endblock %}
