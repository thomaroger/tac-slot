{% extends 'base.html.twig' %}

{% block body %}
<div class="container-fluid py-4 home-page">

    <section class="home-section mb-5">
        <div class="home-section-header">
            <p class="home-section-kicker mb-1">Temps réel</p>
            <h2 class="home-section-title mb-0">État de la salle</h2>
        </div>

    {% if slotnow %}
    <div class="alert alert-warning" role="alert">
        <h4 class="alert-heading"><i class="fa-solid fa-map-pin"></i> <strong>Votre séance est en cours</strong></h4>
        <p>Pensez à faire votre check-in.</p>
        <form method="post" action="{{ path('reservation_check', {id: slotnow.id}) }}" class="float-end">
            <input type="hidden" name="_token" value="{{ csrf_token('reservation_check_' ~ slotnow.id) }}">
            <button class="btn btn-dark btn-sm" id="checkinBtn" type="submit">Check-in</button>
        </form>
        <div class="clearfix">&nbsp;</div>
    </div>
    {% endif %}

    {% if slotopened == true %}
        <div class="alert alert-success" role="alert">
        <h4 class="alert-heading">Salle ouverte !</h4>
        <p><strong>{{slotReservations|length}} personne{% if slotReservations|length > 1 %}s{% endif %}</strong> présente{% if slotReservations|length > 1 %}s{% endif %} en salle sur <strong>{{slotResa}} inscrite{% if slotResa > 1 %}s{% endif %}</strong>.</p>
        <hr>
        <p class="mb-0">
            {% for slotReservation in slotReservations %}
{% if not loop.first %},
{% endif %}
{{slotReservation.user.getFirstname()}}
{{slotReservation.user.getLastname()}}
{% if slotReservation.user.hasAirKey() %}
	<span class="status-badge badge-airkey">
		<i class="fa-solid fa-key" aria-hidden="true"></i>
		AirKey</span>
{% endif %}

            {% endfor %}
        </p>
        </div>
    {% endif %}
    
    {% if slotopened == false  %}
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">Salle fermée !</h4>
            <p>Aucun créneau n'est disponible à cette heure</p>
        </div>
    {% endif %}
    </section>

    <section class="home-section">
        <div class="home-section-header">
            <p class="home-section-kicker mb-1">Planning</p>
            <h2 class="home-section-title mb-0">Réservation des créneaux</h2>
            <p class="home-section-subtitle mb-0">Choisissez un jour puis un créneau disponible.</p>
        </div>

    <!-- Accordion horizontal -->
    <div class="accordion" id="weekAccordion">
        {% for day, slots in slotsByDay %}
            {% set dayId = 'day' ~ loop.index %}
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button {{ not loop.first ? 'collapsed' : '' }}" 
                            type="button" 
                            data-bs-toggle="collapse" 
                            data-bs-target="#{{ dayId }}">
                        {{ day|fr_date('l d F')|upper }}
                    </button>
                </h2>
                <div id="{{ dayId }}" 
                     class="accordion-collapse collapse {{ loop.first ? 'show' : '' }}" 
                     data-bs-parent="#weekAccordion">
                    <div class="accordion-body">
                        {% for slot in slots %}
                            {% set remaining = slot.maxPlaces - slot.reservedPlaces %}
                            {% set slotState = 'normal' %}
                            {% if slot.isClosed %}
                                {% set slotState = 'closed' %}
                            {% elseif slot.isReservedBy(app.user, 'pending') %}
                                {% set slotState = 'pending' %}
                            {% elseif slot.isReservedBy(app.user) %}
                                {% set slotState = 'reserved' %}
                            {% elseif remaining <= 0 %}
                                {% set slotState = 'full' %}
                            {% endif %}

                            <div class="card slot-card slot-state-{{ slotState }} mb-2 mb-md-3 p-2 p-md-3 rounded-3" id='slot-{{slot.id}}'>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>{{ slot.startAt|date('H:i') }} - {{ slot.endAt|date('H:i') }}</strong><br>
                                       {% if slot.isReservedBy(app.user) %}
                                            <div>{{ remaining }} / {{ slot.maxPlaces }} places</div>
                                            <div class="status-badges mt-1">
                                                {% if slot.hasReservationWithAirKey %}
                                                    <span class="status-badge badge-airkey"><i class="fa-solid fa-key"></i> AirKey</span>
                                                {% endif %}
                                                <span class="status-badge badge-reserved"><i class="fa-solid fa-check"></i> Réservé</span>
                                                {% if slot.isReservedByWithCheckIn(app.user) %}
                                                    <span class="status-badge badge-checkin"><i class="fa-solid fa-map-pin"></i> Check-in</span>
                                                {% endif %}
                                            </div>
                                        {% elseif remaining <= 0 %}
                                            <span class="status-badge badge-full"><i class="fa-solid fa-people-pulling"></i> Complet</span>
                                        {% else %}
                                            {% if not slot.isClosed %}
                                                {{ remaining }} / {{ slot.maxPlaces }} places
                                                {% if slot.hasReservationWithAirKey %}
                                                    <div class="status-badges mt-1">
                                                        <span class="status-badge badge-airkey"><i class="fa-solid fa-key"></i> AirKey disponible</span>
                                                    </div>
                                                {% endif %}
                                            {% else %}
                                                <span class="status-badge badge-closed"><i class="fa-solid fa-lock"></i> Fermé</span>
                                            {% endif %}
                                        {% endif %}
                                    </div>
                                    <div>
                                        {% if slot.isReservedBy(app.user)  %}
                                            {% if slot.canBeCancelled %}
                                            <button class="btn btn-outline-danger btn-sm cancelledReservation" 
                                                    data-slot-id="{{ slot.id }}" 
                                                    data-action="cancel">Annuler</button>
                                            {% else %}
                                                <button class="btn btn-outline-secondary btn-sm" disabled>Annuler</button>
                                            {% endif %}
                                        {% else %}
                                            {%if slot.isClosed %}
                                                <button class="btn btn-outline-secondary btn-sm" disabled>Fermé</button>
                                            {% else %}
                                            {% if remaining > 0 %}
                                                {% if not user.hasAirKey and not slot.hasReservationWithAirKey %}
                                                    <button class="btn btn-secondary btn-sm" disabled>AirKey nécessaire</button>
                                                {% else %}
                                                    {% if slot.isReservedBy(app.user, 'pending') %}
                                                        <button class="btn btn-sm btn-pending-confirm confirmReservationSincePending" data-slot-id="{{slot.id}}">A confirmer</button>
                                                    {% else %}
                                                    <button class="btn btn-success btn-sm" 
                                                            data-slot-id="{{ slot.id }}" 
                                                            data-action="reserve"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#reservationModal"
                                                            data-slot-day="{{ day|fr_date('l d F')|upper }}"
                                                            data-slot-time="{{ slot.startAt|date('H:i') }} - {{ slot.endAt|date('H:i') }}"
                                                            data-remaining="{{ remaining }}">Réserver</button>
                                                    {% endif %}
                                                {% endif %}
                                            {% elseif remaining == 0 %}
                                                <button class="btn btn-outline-secondary btn-sm" disabled>Complet</button>
                                            {% endif %}
                                            {% endif %}
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
    </section>
</div>

<!-- Modal Réservation -->
<div class="modal fade modal-slot-reservation" id="reservationModal" tabindex="-1" data-csrf-token="{{ csrf_token('slot_reserve') }}">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4">
            <div class="modal-header border-1">
                <h5 class="modal-title fw-bold">Confirmer la réservation</h5>
                <button type="button" class="btn-close" id="btn-close-modal" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <p><strong id="slotDay"></strong><br /><span id="slotTime"></strong><hr /></p>
                <p><strong>Places restantes : <span id="remainingPlaces"></span></strong></p>
                <hr />   
                <h6 class="">⏳ Il vous reste <span id="countdown">60</span> secondes pour confirmer votre réservation.</h6>
                <hr />   
                <p class="small"><span class="text-warning"><i class="fa-solid fa-check"></i>Annulation possible jusqu’à 30 min avant.</span><br />
                <span class="text-success"><i class="fa-solid fa-check"></i> Check-in obligatoire à l'arrivée.</span><br />
                <span class="text-danger"><i class="fa-solid fa-xmark"></i> Absence sans check-in = no show.</span></p>
            </div>
            <div class="modal-footer border-1">
                <button type="button" class="btn btn-danger" data-slot-id="" id="cancelledReservation" data-bs-dismiss="modal">Annuler ma réservation</button>
                <button type="button" class="btn btn-success" data-slot-id="" id="confirmReservation" >Confirmer ma réservation</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}
